# Google AI Studio / Gemini API Key
# Erstellen unter: https://aistudio.google.com/apikey
GEMINI_API_KEY=ihr_api_key_hier

# Optional: Modell (Standard: gemini-flash-latest mit Fallback-Kette)
# GEMINI_MODEL=gemini-flash-latest

# Passwortschutz (Vercel: nur in Project Settings setzen, nicht committen)
# Wenn SITE_PASSWORD gesetzt ist, erscheint ein Browser-Passwort-Dialog vor der ganzen Seite.
# SITE_USERNAME=preview
# SITE_PASSWORD=ihr_geheimes_passwort
