{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/berater", "destination": "/berater.html" },
    { "source": "/foerderung", "destination": "/foerderung.html" },
    { "source": "/checkliste", "destination": "/checkliste.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet"
        }
      ]
    }
  ]
}
